{
  "name": "rezepti",
  "version": "1.0.0",
  "description": "Rezept-Extraktor mit SQLite-Export",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "dev:react": "vite",
    "dev:docker": "concurrently \"npm run dev\" \"cd frontend && npm run dev -- --host 0.0.0.0\"",
    "build:react": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "tsx scripts/migrate-to-react-db.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "better-sqlite3": "^9.0.0",
    "cheerio": "^1.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.7.0",
    "lucide-react": "^0.577.0",
    "openai": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.2.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^1.3.0",
    "drizzle-kit": "^0.28.0",
    "happy-dom": "^13.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vite": "^5.1.0",
    "vitest": "^1.3.0"
  }
}
