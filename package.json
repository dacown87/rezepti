{
  "name": "rezepti",
  "version": "1.0.10",
  "description": "Rezept-Extraktor mit SQLite-Export",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "dev:react": "vite",
    "dev:docker": "concurrently \"npm run dev\" \"cd frontend && npm run dev -- --host 0.0.0.0\"",
    "build:react": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "vitest run test/e2e",
    "test:unit": "vitest run test/unit",
    "test:docker": "vitest run test/e2e/docker.test.ts",
    "test:performance": "tsx test/utils/performance-test.ts",
    "test:local": "bash test/scripts/test-local.sh",
    "test:docker-full": "bash test/scripts/test-docker.sh",
    "test:all": "npm run test:unit && npm run test:e2e && npm run test:docker",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "tsx scripts/migrate-to-react-db.ts",
    "docker:dev": "docker compose --profile react up",
    "docker:dev:build": "docker compose --profile react up --build",
    "docker:dev:logs": "docker compose --profile react logs -f",
    "docker:prod": "docker compose --profile react-prod up -d",
    "docker:prod:build": "docker compose --profile react-prod up --build",
    "docker:prod:logs": "docker compose --profile react-prod logs -f",
    "docker:legacy": "docker compose --profile prod up -d",
    "docker:legacy:logs": "docker compose --profile prod logs -f",
    "docker:stop": "docker compose --profile react --profile react-prod --profile prod down",
    "docker:stats": "docker stats --no-stream",
    "docker:clean": "docker system prune -f && docker volume prune -f",
    "docker:shell": "docker compose --profile react exec rezepti-react /bin/sh",
    "docker:shell:prod": "docker compose --profile react-prod exec rezepti-react-prod /bin/sh",
    "docker:health": "curl -s http://localhost:3000/api/health",
    "docker:backup": "mkdir -p backups && tar -czf backups/rezepti-$(date +%Y%m%d).tar.gz data/",
    "docker:restore": "tar -xzf backups/rezepti-20260322.tar.gz"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@testing-library/dom": "^10.4.1",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.0",
    "lucide-react": "^1.6.0",
    "openai": "^6.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.8.8",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^3.2.4"
  }
}
