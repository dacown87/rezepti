# Groq API (kostenlos, https://console.groq.com)
GROQ_API_KEY=gsk_...

# Optionale Modell-Overrides
# GROQ_TEXT_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# SQLite-Datenbank (Standard: ./data/rezepti.db)
# SQLITE_PATH=./data/rezepti.db

# Server
PORT=3000

# Cookidoo (cookidoo.de) — optional, für Rezept-Import von cookidoo.de
# Trage hier deine Thermomix-/Cookidoo-Zugangsdaten ein.
# Die App nutzt den Vorwerk Mobile App API (OAuth2 ROPC), kein Scraping.
COOKIDOO_EMAIL=deine@email.de
COOKIDOO_PASSWORD=deinPasswort

# Facebook — optional, für Video-Import von facebook.com
# Cookies werden als Netscape-Format in data/facebook-cookies.txt erwartet.
# Siehe data/facebook-cookies.txt.example für das Format.
# Cookies können mit der Browser-Extension "Get cookies.txt LOCALLY" exportiert werden.
# Pfad: data/facebook-cookies.txt (wird automatisch von der App gelesen)
